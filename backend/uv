#!/usr/bin/env python3
"""Small uvicorn runner so you can call `python uv [app:app] [--host HOST] [--port PORT]`.
If no app is provided it defaults to `app.main:app`.
"""
import sys
import uvicorn


def parse_args(args):
    app = None
    host = "127.0.0.1"
    port = 8000
    idx = 0
    if idx < len(args) and not args[idx].startswith("-"):
        app = args[idx]
        idx += 1
    while idx < len(args):
        a = args[idx]
        if a == "--host":
            idx += 1
            if idx < len(args):
                host = args[idx]
        elif a == "--port":
            idx += 1
            if idx < len(args):
                try:
                    port = int(args[idx])
                except ValueError:
                    pass
        idx += 1
    if app is None:
        app = "app.main:app"
    return app, host, port


def main():
    app, host, port = parse_args(sys.argv[1:])
    uvicorn.run(app, host=host, port=port)


if __name__ == "__main__":
    main()
