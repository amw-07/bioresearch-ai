# BioResearch AI — environment variables for local development.
# GEMINI_API_KEY is optional. Without it the system runs with 3/4 AI components
# (ML scorer + semantic search + SHAP explainability) but skips LLM intelligence generation.

DATABASE_URL=postgresql+asyncpg://user:pass@host/db
REDIS_URL=redis://default:password@host:port
PUBMED_EMAIL=your@email.com
PUBMED_API_KEY=optional_ncbi_key
# Model string — must match Google AI Studio model ID exactly:
GEMINI_MODEL=gemini-3-flash-preview
SECRET_KEY=run_uv_run_python_-c_import_secrets_print_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEBUG=false
LOG_LEVEL=INFO