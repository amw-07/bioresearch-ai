# BioResearch AI — Backend Environment Variables
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
REDIS_URL=redis://default:password@host:6379

PUBMED_EMAIL=your@email.com
PUBMED_API_KEY=                        # optional — increases NCBI rate limits
ANTHROPIC_API_KEY=                     # optional — Component 3 degrades gracefully without it

SECRET_KEY=replace_with_32_random_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440       # 24 hours

DEBUG=false
LOG_LEVEL=INFO
