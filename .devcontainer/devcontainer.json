{
  "name": "BioResearch AI",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Install uv (fast Python package manager used by this project)
  "onCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && echo 'export PATH=$HOME/.cargo/bin:$PATH' >> ~/.bashrc",

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "forwardPorts": [8000, 3000],

  "portsAttributes": {
    "8000": {
      "label": "FastAPI Backend",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Next.js Frontend",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "GitHub.copilot",
        "eamodio.gitlens",
        "ms-vscode.vscode-typescript-next",
        "Prisma.prisma",
        "mtxr.sqltools",
        "ckolkman.vscode-postgres"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "secrets": {
    "DATABASE_URL": {
      "description": "Supabase PostgreSQL connection string (postgresql+asyncpg://...)"
    },
    "REDIS_URL": {
      "description": "Upstash Redis connection string"
    },
    "GEMINI_API_KEY": {
      "description": "Google AI Studio key — free at https://aistudio.google.com/app/apikey"
    },
    "PUBMED_EMAIL": {
      "description": "Your email address for NCBI PubMed API"
    },
    "SECRET_KEY": {
      "description": "Random 32-char string: python -c \"import secrets; print(secrets.token_hex(32))\""
    }
  }
}